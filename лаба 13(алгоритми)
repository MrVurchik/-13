#include <iostream>
#include <vector>
#include <queue>
#include <chrono>
#include <ctime>

using namespace std;
void DFS(vector<int> adjList[], int start, bool visited[]) {
    visited[start] = true;
    cout << "Now i am here on top " << start << endl;

    for (int neighbor : adjList[start]) {
        if (!visited[neighbor]) {
            DFS(adjList, neighbor, visited);
        }
    }
}
void BFS(vector<int> adjList[], int start, bool visited[], int k) {
    queue<int> que;
    visited[start] = true;
    que.push(start); 

    while (!que.empty()) {
        int v = que.front(); 
        que.pop();           
        cout << "Now top is " << v << endl;

        for (int neighbor : adjList[v]) {
            if (!visited[neighbor]) {
                visited[neighbor] = true;
                que.push(neighbor);
            }
        }
    }
}

int main() {
    srand(time(0));

    cout << "How mane top for list: ";
    int k;
    cin >> k;

    
    bool* visitedDFS = new bool[k] {false};
    bool* visitedBFS = new bool[k] {false};

    int m = k * 2; 

    
    vector<int>* adjList = new vector<int>[k];

    
    for (int i = 0; i < m; i++) {
        
        if (m > (k * (k - 1) / 2)) {
            cout << "Too many edges for this graph!" << endl;
            break;
        }

        int value = rand() % k;
        int index = rand() % k;

        bool exists = false;
        for (int neighbor : adjList[index]) {
            if (neighbor == value) {
                exists = true;
                break;
            }
        }

        if (index != value && !exists) {
            adjList[index].push_back(value);
            adjList[value].push_back(index);
        }
        else {
            i--;
        }
    }


    for (int i = 0; i < k; i++) {
        cout << "For top " << i << ": ";
        for (int neighbor : adjList[i]) {
            cout << neighbor << " ";
        }
        cout << endl;
    }

    cout << "\n--- DFS START ---" << endl;
    auto startDFS = chrono::high_resolution_clock::now();

    DFS(adjList, 0, visitedDFS);

    auto endDFS = chrono::high_resolution_clock::now();
    auto durationDFS = chrono::duration_cast<chrono::nanoseconds>(endDFS - startDFS).count();
    cout << "DFS Time: " << durationDFS << " ns" << endl;


    cout << "\n--- BFS START ---" << endl;
    auto startBFS = chrono::high_resolution_clock::now();

    BFS(adjList, 0, visitedBFS, k);

    auto endBFS = chrono::high_resolution_clock::now();
    auto durationBFS = chrono::duration_cast<chrono::nanoseconds>(endBFS - startBFS).count();
    cout << "BFS Time: " << durationBFS << " ns" << endl;

   
    delete[] adjList;
    delete[] visitedDFS;
    delete[] visitedBFS;

    return 0;
}
