// Схема Хоара для QuickSort
int SortHoara(int a[], int left, int right) {
    int pivot = a[(left + right) / 2];
    int i = left - 1;
    int j = right + 1;
    while (true) {
        do { i++; } while (a[i] < pivot);
        do { j--; } while (a[j] > pivot);
        if (i >= j) return j;
        swap(a[i], a[j]);
    }
}

// Рекурсивна функція QuickSort
void QucklySort(int a[], int left, int right) {
    if (left < right) {
        int pivot2 = SortHoara(a, left, right);
        QucklySort(a, left, pivot2);
        QucklySort(a, pivot2 + 1, right);
    }
}

// Сортування Шелла
void SortShela(int arr[], int n) {
    for (int gap = n / 2; gap > 0; gap /= 2) {
        for (int i = gap; i < n; i++) {
            int temp = arr[i];
            int j;
            for (j = i; j >= gap && arr[j - gap] > temp; j -= gap) {
                arr[j] = arr[j - gap];
            }
            arr[j] = temp;
        }
    }
}

