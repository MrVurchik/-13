filename = "file.txt"
with open(filename, "w", encoding="utf-8") as keyfile:
    for i in range(1, 11):
        keyfile.write(str(i + "\n")) 

print("Парні числа з файлу:")
with open(filename, "r", encoding="utf-8") as keyfile:
    for line in keyfile:             
        num = int(line.strip())      
        if num % 2 == 0:
            print(num)



