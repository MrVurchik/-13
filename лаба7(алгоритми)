void InsertSort(vector<int>& f) {
    for (int i = 1; i < f.size(); i++) {
        int key = f[i];
        int j = i - 1;
        while (j >= 0 && f[j] > key) {
            f[j + 1] = f[j];
            j--;
        }
        f[j + 1] = key;
    }
}


void CountSort(vector<int>& arr) {
    if (arr.empty()) return;

    int maxVal = arr[0];
    for (int i = 1; i < arr.size(); i++) {
        if (arr[i] > maxVal) maxVal = arr[i];
    }

    vector<int> count(maxVal + 1, 0);
    for (int i = 0; i < arr.size(); i++) {
        count[arr[i]]++;
    }

    int index = 0;
    for (int i = 0; i <= maxVal; i++) {
        while (count[i] > 0) {
            arr[index++] = i;
            count[i]--;
        }
    }
}
void BucketSort(vector<int>& arr) {
    int n = arr.size();
    if (n <= 1) return;

    int maxVal = arr[0], minVal = arr[0];
    for (int i = 1; i < n; i++) {
        if (arr[i] > maxVal) maxVal = arr[i];
        if (arr[i] < minVal) minVal = arr[i];
    }

    int k = (int)sqrt(n);
    if (k < 2) k = 2;

    vector<vector<int>> buckets(k);

    for (int i = 0; i < n; i++) {
        int bucketIndex = 0;
        if (maxVal != minVal) {
            float normalized = (float)(arr[i] - minVal) / (maxVal - minVal);
            bucketIndex = (int)(normalized * (k - 1));
        }
        buckets[bucketIndex].push_back(arr[i]);}

    int index = 0;
    for (int i = 0; i < k; i++) {
        InsertSort(buckets[i]);
        for (int val : buckets[i]) {
            arr[index] = val;
            index++;
        }
    }
}

