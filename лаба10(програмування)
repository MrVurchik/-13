# 11.2.2. Робота з датами
date_birthday = input("Вкажіть дату народження (день:місяць:рік): ")
birthday = datetime.strptime(date_birthday, "%d:%m:%Y")
now = datetime.now()

years = now.year - birthday.year
print(f"You are {years} years old")

this_year_birthday = birthday.replace(year=now.year)

if this_year_birthday < now:
    next_birthday = this_year_birthday.replace(year=now.year + 1)
else:
    next_birthday = this_year_birthday
diff = next_birthday - now
print(f"Your next birthday is in {diff.days} days")
