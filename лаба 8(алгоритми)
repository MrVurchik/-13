#include <iostream>
#include <chrono>

using namespace std;
class StackNode {
public:
    int data;
    StackNode* next;
    StackNode(int value) {
        data = value;
        next = nullptr;
    }
};
class Stack {
private:
    int* stackArray;
    int top;
    int capacity;

public:
    Stack(int size) {
        capacity = size;
        stackArray = new int[size];
        top = -1;
    }

    ~Stack() {
        delete[] stackArray;
    }

    void Push(int value) {
        if (top < capacity - 1) {
            stackArray[++top] = value;
        }
    }

    int Pop2() {
        if (top >= 0) return stackArray[top--];
        return -1;
    }
};
class LinkedListStack {
private:
    StackNode* head;

public:
    LinkedListStack() {
        head = nullptr;
    }

    ~LinkedListStack() {
        while (head != nullptr) {
            PopStart();
        }
    }

    void PushStart(int value) {
        StackNode* newNode = new StackNode(value);
        newNode->next = head;
        head = newNode;
    }

    int PopStart() {
        if (head != nullptr) {
            StackNode* temp = head;
            int value = head->data;
            head = head->next;
            delete temp;
            return value;
        }
        return -1;
    }
};
int main() {
    int sizes[] = { 100, 1000, 10000 };
    cout << "------ Array-based Stack -------" << endl;
    for (int size : sizes) {
        Stack s(size);
        auto start = chrono::high_resolution_clock::now();
        for (int i = 0; i < size; i++) s.Push(i);
        auto end = chrono::high_resolution_clock::now();
        auto pushTime = chrono::duration_cast<chrono::nanoseconds>(end - start);

        start = chrono::high_resolution_clock::now();
        for (int i = 0; i < size; i++) s.Pop2();
        end = chrono::high_resolution_clock::now();
        auto popTime = chrono::duration_cast<chrono::nanoseconds>(end - start);

        cout << "Size " << size << " | Push: " << pushTime.count() << " ns | Pop: " << popTime.count() << " ns" << endl;
    }

    
    cout << "------ Linked List-based Stack -------" << endl;
    for (int size : sizes) {
        LinkedListStack ls;

        auto start = chrono::high_resolution_clock::now();
        for (int i = 0; i < size; i++) ls.PushStart(i);
        auto end = chrono::high_resolution_clock::now();
        auto pushTime = chrono::duration_cast<chrono::nanoseconds>(end - start);

        start = chrono::high_resolution_clock::now();
        for (int i = 0; i < size; i++) ls.PopStart();
        end = chrono::high_resolution_clock::now();
        auto popTime = chrono::duration_cast<chrono::nanoseconds>(end - start);

        cout << "Size " << size << " | Push: " << pushTime.count() << " ns | Pop: " << popTime.count() << " ns" << endl;
    }

    return 0;
}
